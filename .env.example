# Last.fm API Credentials
# Get these from: https://www.last.fm/api/account/create
LASTFM_API_KEY=your_lastfm_api_key_here
LASTFM_API_SECRET=your_lastfm_api_secret_here
LASTFM_USERNAME=your_lastfm_username
LASTFM_PASSWORD=your_lastfm_password

# Mobile Gap-Filling Configuration
# How many hours back to check Last.fm for existing scrobbles (default: 2)
RECENT_WINDOW_HOURS=2

# Maximum tracks to scrobble per run to avoid rate limiting (default: 20)
MAX_SCROBBLES_PER_RUN=20

# Enable mobile detection to avoid duplicate scrobbles (default: true)
ENABLE_MOBILE_DETECTION=true

# Dry run mode - preview what would be scrobbled without actually scrobbling (default: false)
DRY_RUN=false